# PostgreSQL connection string (required)
# For Vercel Postgres / Neon: use the connection string from your dashboard
DATABASE_URL="postgresql://user:password@localhost:5432/workhorse"

# Anthropic API key (required for AI chat and review features)
ANTHROPIC_API_KEY=""

# GitHub OAuth app credentials (required for authentication)
# Create an OAuth app at https://github.com/settings/developers
# Set the callback URL to http://localhost:3000/api/auth/github/callback
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# Base URL of the application (used for OAuth redirect)
NEXTAUTH_URL="http://localhost:3000"
