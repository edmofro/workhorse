generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String   @id @default(cuid())
  githubId       Int      @unique
  githubUsername  String
  displayName    String
  avatarUrl      String?
  accessToken    String   // GitHub OAuth access token (for API calls on behalf of user)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  cards                Card[]
  cardActivities       CardActivity[]
  comments             CardComment[]
  fileLocks            FileLock[]
  attachments          Attachment[]
  conversationSessions ConversationSession[]
}

model Project {
  id            String   @id @default(cuid())
  name          String   // e.g., "Tamanu", "Tupaia"
  githubUrl     String   @unique
  owner         String   // GitHub org/user
  repoName      String   // GitHub repo name
  defaultBranch String   @default("main")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  teams Team[]
}

model Team {
  id        String   @id @default(cuid())
  name      String
  colour    String   @default("#c2410c")
  projectId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project              Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  cards                Card[]
  conversationSessions ConversationSession[]

  @@index([projectId])
}

model Card {
  id              String   @id @default(cuid())
  identifier      String   @unique // e.g., "WH-001"
  title           String
  description     String?
  status          String   @default("NOT_STARTED") // NOT_STARTED, SPECIFYING, IMPLEMENTING, COMPLETE
  priority        String   @default("MEDIUM") // URGENT, HIGH, MEDIUM, LOW
  teamId          String
  assigneeId      String?
  tags            String   @default("[]") // JSON array of strings
  cardBranch      String?  // Git branch for this card's work (internal, not surfaced to user)
  touchedFiles    String   @default("[]") // JSON array of file paths this card has modified
  prNumber        Int?     // GitHub PR number
  prUrl           String?  // GitHub PR URL
  lastActivityAt  DateTime @default(now()) // For stale worktree cleanup

  // Quality step tracking
  interviewCompleted    Boolean  @default(false) // Substantive interview (not just one-shot draft)
  specReviewCompleted   Boolean  @default(false) // Fresh-eyes review agent has run
  designAuditCompleted  Boolean  @default(false) // Design audit agent has run (implementation phase)
  securityAuditCompleted Boolean @default(false) // Security audit agent has run (implementation phase)
  codeReviewCompleted   Boolean  @default(false) // Code review agent has run (implementation phase)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  team         Team             @relation(fields: [teamId], references: [id], onDelete: Cascade)
  assignee     User?            @relation(fields: [assigneeId], references: [id], onDelete: SetNull)
  activities   CardActivity[]
  mockups      Mockup[]
  comments     CardComment[]
  attachments  Attachment[]
  fileLocks    FileLock[]
  dependsOn    CardDependency[] @relation("dependent")
  dependedOnBy CardDependency[] @relation("parent")
  sessions     ConversationSession[]

  @@index([teamId])
  @@index([assigneeId])
  @@index([status])
  @@index([createdAt(sort: Desc)])
}

model Mockup {
  id        String   @id @default(cuid())
  cardId    String
  title     String
  html      String   // the HTML/CSS content
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@index([cardId])
}

model CardDependency {
  dependentId String
  parentId    String

  dependent Card @relation("dependent", fields: [dependentId], references: [id], onDelete: Cascade)
  parent    Card @relation("parent", fields: [parentId], references: [id], onDelete: Cascade)

  @@id([dependentId, parentId])
  @@index([parentId])
}

model FileLock {
  id        String   @id @default(cuid())
  cardId    String
  filePath  String
  lockedBy  String   // user ID or "ai-agent"
  userId    String?  // null when lockedBy is "ai-agent"
  lockedAt  DateTime @default(now())
  expiresAt DateTime // 10 min for humans, 2 min for AI

  card Card  @relation(fields: [cardId], references: [id], onDelete: Cascade)
  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@unique([cardId, filePath])
  @@index([cardId])
  @@index([expiresAt])
}

model CardActivity {
  id        String   @id @default(cuid())
  cardId    String
  userId    String?
  action    String   // "created", "status_changed", "spec_updated", "committed", "dependency_added", "dependency_removed", "marked_ready"
  details   String?  // JSON with action-specific data
  createdAt DateTime @default(now())

  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)
  user User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([cardId])
  @@index([userId])
  @@index([createdAt(sort: Desc)])
}

model CardComment {
  id        String   @id @default(cuid())
  cardId    String
  userId    String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  card        Card         @relation(fields: [cardId], references: [id], onDelete: Cascade)
  user        User         @relation(fields: [userId], references: [id])
  attachments Attachment[]

  @@index([cardId])
  @@index([userId])
  @@index([createdAt(sort: Desc)])
}

model Attachment {
  id           String   @id @default(cuid())
  cardId       String?
  commentId    String?
  uploadedById String
  fileName     String
  mimeType     String
  fileSize     Int
  storagePath  String
  createdAt    DateTime @default(now())

  card       Card?        @relation(fields: [cardId], references: [id], onDelete: Cascade)
  comment    CardComment? @relation(fields: [commentId], references: [id], onDelete: Cascade)
  uploadedBy User         @relation(fields: [uploadedById], references: [id])

  @@index([cardId])
  @@index([commentId])
  @@index([uploadedById])
}

model ConversationSession {
  id              String   @id @default(cuid())
  cardId          String?
  teamId          String?
  userId          String
  agentSessionId  String?  // Agent SDK session ID for resumption
  title           String?  // Auto-generated from first exchange
  messageCount    Int      @default(0)
  lastMessageAt   DateTime @default(now())
  createdAt       DateTime @default(now())

  card Card? @relation(fields: [cardId], references: [id], onDelete: Cascade)
  team Team? @relation(fields: [teamId], references: [id], onDelete: SetNull)
  user User  @relation(fields: [userId], references: [id])

  @@index([cardId, lastMessageAt(sort: Desc)])
  @@index([userId, lastMessageAt(sort: Desc)])
}
