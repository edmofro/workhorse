# PostgreSQL connection string (required)
# For Vercel Postgres / Neon: use the connection string from your dashboard
DATABASE_URL="postgresql://user:password@localhost:5432/workhorse"

# Anthropic API key (required for AI chat and review features)
ANTHROPIC_API_KEY=""

# GitHub personal access token (required for spec commit and explorer features)
# Needs repo read/write permissions
GITHUB_TOKEN=""
