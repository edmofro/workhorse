generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String   @id @default(cuid())
  githubId       Int      @unique
  githubUsername  String
  displayName    String
  avatarUrl      String?
  accessToken    String   // GitHub OAuth access token (for API calls on behalf of user)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  cards             Card[]
  specMessages      SpecMessage[]
  cardActivities    CardActivity[]
  teamMemberships   TeamMember[]
  comments          CardComment[]
}

model Project {
  id            String   @id @default(cuid())
  name          String   // e.g., "Tamanu", "Tupaia"
  githubUrl     String   @unique
  owner         String   // GitHub org/user
  repoName      String   // GitHub repo name
  defaultBranch String   @default("main")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  teams Team[]
}

model Team {
  id        String   @id @default(cuid())
  name      String
  colour    String   @default("#c2410c")
  projectId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project  Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  cards    Card[]
  members  TeamMember[]
}

model TeamMember {
  userId    String
  teamId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@id([userId, teamId])
}

model Card {
  id          String   @id @default(cuid())
  identifier  String   @unique // e.g., "WH-001"
  title       String
  description String?
  status      String   @default("NOT_STARTED") // NOT_STARTED, SPECIFYING, SPEC_COMPLETE
  priority    String   @default("MEDIUM") // URGENT, HIGH, MEDIUM, LOW
  teamId      String
  assigneeId  String?
  tags        String   @default("[]") // JSON array of strings
  specBranch  String?  // Git branch (internal, not surfaced to user)
  prNumber    Int?     // GitHub PR number
  prUrl       String?  // GitHub PR URL (shown next to commit button)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  team         Team             @relation(fields: [teamId], references: [id], onDelete: Cascade)
  assignee     User?            @relation(fields: [assigneeId], references: [id], onDelete: SetNull)
  specMessages SpecMessage[]
  activities   CardActivity[]
  specs        CardSpec[]
  mockups      Mockup[]
  comments     CardComment[]
  dependsOn    CardDependency[] @relation("dependent")
  dependedOnBy CardDependency[] @relation("parent")
}

model CardSpec {
  id               String   @id @default(cuid())
  cardId           String
  filePath         String   // e.g., ".workhorse/specs/patient/allergies.md"
  isNew            Boolean  @default(true) // new spec vs editing existing
  content          String   // current content (auto-saved to DB)
  baselineContent  String?  // content from main at time of attachment (for tracked-changes diff)
  committedContent String?  // content as of last commit (null = never committed)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@unique([cardId, filePath])
}

model Mockup {
  id        String   @id @default(cuid())
  cardId    String
  title     String
  html      String   // the HTML/CSS content
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)
}

model CardDependency {
  dependentId String
  parentId    String

  dependent Card @relation("dependent", fields: [dependentId], references: [id], onDelete: Cascade)
  parent    Card @relation("parent", fields: [parentId], references: [id], onDelete: Cascade)

  @@id([dependentId, parentId])
}

model SpecMessage {
  id        String   @id @default(cuid())
  cardId    String
  userId    String?
  role      String   // "user", "assistant", "system"
  content   String
  metadata  String?  // JSON for mockup references, extracted specs, auto-review results, etc.
  createdAt DateTime @default(now())

  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)
  user User?   @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model CardActivity {
  id        String   @id @default(cuid())
  cardId    String
  userId    String?
  action    String   // "created", "status_changed", "spec_updated", "committed", "dependency_added", "dependency_removed"
  details   String?  // JSON with action-specific data
  createdAt DateTime @default(now())

  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)
  user User?   @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model CardComment {
  id        String   @id @default(cuid())
  cardId    String
  userId    String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id])
}
